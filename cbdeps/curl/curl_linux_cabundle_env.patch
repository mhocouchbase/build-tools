diff --git a/CMakeLists.txt b/CMakeLists.txt
index e459b3d076..72d03f31e5 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -1126,6 +1126,9 @@ if(USE_NGHTTP2)
