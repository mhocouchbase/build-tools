   elseif(CURL_CA_BUNDLE STREQUAL "none")
     unset(CURL_CA_BUNDLE CACHE)
   elseif(CURL_CA_BUNDLE STREQUAL "auto")
diff --git a/acinclude.m4 b/acinclude.m4
